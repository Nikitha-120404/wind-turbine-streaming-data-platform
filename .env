# ─────────────────────────────────────────────────────────────────────────────
# Wind Turbine Platform — Environment Configuration
# Copy this file to .env and set your values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Kafka ──────────────────────────────────────────────────────────────────────
# Use localhost:9092 when running services outside Docker
# Use kafka:29092 when running services inside Docker Compose network
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

KAFKA_TOPIC_RAW=windturbine-raw
KAFKA_TOPIC_ALERTS=windturbine-alerts
KAFKA_TOPIC_DLQ=windturbine-dlq

KAFKA_CONSUMER_GROUP_PROCESSOR=wt-stream-processor
KAFKA_CONSUMER_GROUP_DB_WRITER=wt-db-writer

KAFKA_NUM_PARTITIONS_RAW=6
KAFKA_NUM_PARTITIONS_ALERTS=3
KAFKA_NUM_PARTITIONS_DLQ=2

# Producer reliability
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=5
KAFKA_PRODUCER_RETRY_BACKOFF_MS=300
KAFKA_PRODUCER_MAX_IN_FLIGHT=1
KAFKA_PRODUCER_ENABLE_IDEMPOTENCE=true

# ── Database ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=windturbine
DB_USER=wt_user
DB_PASSWORD=wt_password
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT=10

# ── Producer Service ──────────────────────────────────────────────────────────
# 12 turbines — matches original wind_turbine_sensorlog.py which simulated Turbine_1..12
# Format: turbine-01..12 (normalised from original "Turbine_1" format)
PRODUCER_TURBINE_IDS=turbine-01,turbine-02,turbine-03,turbine-04,turbine-05,turbine-06,turbine-07,turbine-08,turbine-09,turbine-10,turbine-11,turbine-12
PRODUCER_EMIT_INTERVAL_SECONDS=1.0
PRODUCER_METRICS_PORT=8001

# Path to a wind_turbine.log file produced by the original wind_turbine_sensorlog.py
# Used only by: python -m services.producer.legacy_ingestor
LOG_FILE=wind_turbine.log

# ── Processor Service ─────────────────────────────────────────────────────────
PROCESSOR_METRICS_PORT=8002
PROCESSOR_MAX_POLL_RECORDS=500
PROCESSOR_SESSION_TIMEOUT_MS=30000

# ── DB Writer Service ─────────────────────────────────────────────────────────
DB_WRITER_METRICS_PORT=8003
DB_WRITER_BATCH_SIZE=100
DB_WRITER_FLUSH_INTERVAL_SECONDS=2.0

# ── Ops API Service ───────────────────────────────────────────────────────────
OPS_API_HOST=0.0.0.0
OPS_API_PORT=8000
OPS_API_METRICS_PORT=8004

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=windturbine
